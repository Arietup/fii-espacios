# ═══════════════════════════════════════════════════════════════════════════════
# VARIABLES DE ENTORNO — fii-espacios
# Copia este archivo a .env.local y completa los valores reales.
# NUNCA subas .env.local al repositorio.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Auth.js v5 (NextAuth) ──────────────────────────────────────────────────────
# Genera un valor con: openssl rand -base64 32
# Obligatorio tanto en desarrollo como en producción.
AUTH_SECRET=""

# ── Base de datos (Prisma Postgres — Vercel) ───────────────────────────────────
# URL de conexión pooled. Se obtiene del dashboard de Vercel Postgres o Prisma.
# Formato: postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=""

# ── Seed (opcionales, solo para poblado inicial) ──────────────────────────────
# Usuario administrador que crea el script prisma/seed.ts
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD=""

# ── Variables de Vercel CLI (solo para GitHub Actions / despliegue manual) ────
# No son necesarias en desarrollo local.
# Consultar DEPLOY.md para obtener estos valores.
VERCEL_TOKEN=""
VERCEL_ORG_ID=""
VERCEL_PROJECT_ID=""
