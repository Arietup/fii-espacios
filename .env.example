# Auth.js / NextAuth
AUTH_SECRET=""
# NEXTAUTH_SECRET is not required by Auth.js v5 when AUTH_SECRET is set.
NEXTAUTH_SECRET=""
# Usually optional on Vercel with Auth.js v5. Set only if redirects need a canonical URL.
NEXTAUTH_URL=""

# Database
# Use Prisma Postgres from the Vercel Marketplace or another Postgres-compatible database.
DATABASE_URL="postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Optional Prisma seed values
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD=""
